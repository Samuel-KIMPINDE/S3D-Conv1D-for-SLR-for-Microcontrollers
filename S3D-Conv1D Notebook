    "print(df_stats.to_string(index=False))\n",
    "\n",
    "print(\"\\n=== Global Statistics ===\")\n",
    "for k, v in global_stats.items():\n",
    "    print(f\"{k}: {v:.2f}\" if isinstance(v, float) else f\"{k}: {v}\")"
