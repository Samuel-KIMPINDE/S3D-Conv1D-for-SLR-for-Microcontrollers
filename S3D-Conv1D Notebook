    "# === Cell 4: Load Dataset & Split ===\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "all_data, all_labels = [], []\n",
    "available_labels = os.listdir(raw_frame_dir)\n",
